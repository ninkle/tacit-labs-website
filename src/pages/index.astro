---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import ascii from "../images/tacit-ascii.png";
import AsciiImage from "../components/AsciiImage.astro";
---

<Layout title="Tacit Labs">
    <main
        class="gap-gutter grid grid-cols-16 h-screen max-h-dvh relative overflow-hidden"
    >
        <div
            class="col-span-16 min-[810px]:w-[550px] flex flex-col grow justify-end p-gutter"
        >
            <h1 class="font-display text-[30px] tracking-normal leading-normal">
                Tacit Labs
            </h1>
            <p
                class="font-mono font-light text-sm tracking-[-0.02em] leading-normal"
            >
                Tacit is an applied research lab at the intersection of AI and
                the life sciences.<br /><br />

                The shape of company that will bring the next generation of
                drugs to market will be model-centric, massively parallelized,
                and increasingly autonomous. Tacit is working across the
                ecosystem to design the blueprint for this kind of company.<br
                /><br />

                We are a team of researchers, engineers, scientists, and
                operators who have trained frontier language models, designed
                and scaled experimental platforms, and brought drugs to the
                clinic.<br /><br />

                <span class="nav-underline"
                    ><a href="/introducing-tacit-labs"
                        >Read more <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.25"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            class="inline-block size-[1em] align-[-0.125em]"
                            ><path d="M7 17 17 7"></path><path d="M8 7h9v9"
                            ></path></svg
                        ></a
                    ></span
                > and/or <span class="nav-underline"
                    ><a href="/join-us"
                        >join us <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.25"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            class="inline-block size-[1em] align-[-0.125em]"
                            ><path d="M7 17 17 7"></path><path d="M8 7h9v9"
                            ></path></svg
                        ></a
                    ></span
                >.
            </p>
        </div>
        <AsciiImage
            src="src/images/tacit-spiral.png"
            cols={150}
            radius={30}
            class="absolute translate-x-[40%] translate-y-[-25%] opacity-30 right-0 h-[calc(90vh+50vw)]"
        />
    </main>

    <script>
        // The composition is tuned at a 2104x1256 viewport. Scale the ascii
        // image uniformly by whichever viewport axis is more constraining so it
        // keeps the same proportions as the window resizes. --ascii-scale is a
        // unitless multiplier consumed by the component's height (and, via its
        // aspect-ratio + percentage translates, its width and position too).
        const REF_W = 1920;
        const REF_H = 1080;

        const setAsciiScale = () => {
            const s = Math.min(
                window.innerWidth / REF_W,
                window.innerHeight / REF_H,
            );
            document.documentElement.style.setProperty(
                "--ascii-scale",
                String(s),
            );
        };

        setAsciiScale();
        window.addEventListener("resize", setAsciiScale);
        // Re-apply after ClientRouter navigations.
        document.addEventListener("astro:page-load", setAsciiScale);
    </script>
</Layout>
