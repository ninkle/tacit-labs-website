---
import Layout from "../layouts/Layout.astro";

const roles = [
    {
        id: "senior-swe",
        title: "Member of Technical Staff — Senior Software Engineer",
        status: "Open",
        description:
            "You'll build the platform that turns our evaluations into infrastructure people actually run against — owning systems end to end, from data model to the interface researchers and partners use. We're looking for someone who has shipped tools for real users before and makes hard plumbing reliable. No biology background required; we'll teach you the science you need.",
    },
    {
        id: "ml-researcher",
        title: "Member of Technical Staff — ML Researcher",
        status: "Open",
        description:
            "You'll design and run the evaluations at the core of what we do: long-horizon, multimodal tests of whether agentic systems can make linked decisions across drug discovery and development. You're at home with evals and have trained or evaluated LLMs. Having worked with raw biochemical readouts is a bonus, not a requirement — the eval instinct is what matters.",
    },
    {
        id: "operations-agents",
        title: "Member of Technical Staff — Operations & Agents",
        status: "Open",
        description:
            "A generalist role for someone early in their career who wants to do a bit of everything: standing up agent workflows, running operations, and absorbing whatever the company needs next. You'd work closely with the founders and effectively become a second pair of hands for them — fast, resourceful, and comfortable with ambiguity and a company that's still taking shape.",
    },
    {
        id: "other",
        title: "Other — not listed",
        status: "Open",
        description:
            "We're always looking for great people who don't neatly fit into the above boxes.",
    },
];
---

<Layout title="Tacit Labs — Join Us">
    <main
        class="p-gutter flex flex-col justify-between items-start h-screen max-h-dvh relative overflow-hidden"
    >
        <!-- Job listings -->
        <div class="flex flex-col justify-center w-full grow">
            <div class="grid grid-cols-16 gap-gutter w-full">
                <div class="col-span-16">
                    <h3
                        class="uppercase font-mono font-light text-xs tracking-normal leading-normal"
                    >
                        Opportunities
                    </h3>
                </div>
                <div
                    id="role-titles"
                    class="flex flex-col gap-0 col-span-16 w-full"
                >
                    {
                        roles.map((r) => (
                            <div
                                data-title
                                data-target={r.id}
                                class="grid grid-cols-16 gap-gutter w-full cursor-pointer transition-opacity duration-200"
                            >
                                <p class="col-span-12 flex font-display text-md">
                                    {r.title}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Bottom: About Tacit (left) + Role description on hover (right) -->
        <div class="grid grid-cols-16 gap-gutter w-full items-start">
            <!-- About Tacit -->
            <div class="col-span-7 col-start-1 flex flex-col gap-3">
                <h3
                    class="uppercase font-mono font-light text-xs tracking-normal leading-normal"
                >
                    About Tacit
                </h3>
                <p class="font-display text-sm tracking-normal leading-normal">
                    Drug development will not be transformed by isolated capability gains.
                    It will be transformed by composing atomic tasks into a decision loop
                    that makes stronger, better-informed choices along the chain of
                    decisions that lead to a drug.
                </p>
                <p class="font-display text-sm tracking-normal leading-normal">
                    Tacit is starting by building realistic, long-horizon evaluations
                    that test whether AI systems can make linked decisions across drug
                    discovery and development. These evaluations combine human reasoning
                    and task design with well-calibrated tools: biological foundation
                    models, raw biological readouts, and easy-to-access lab
                    infrastructure.
                </p>
                <p class="font-display text-sm tracking-normal leading-normal">
                    Tacit is a uniquely shaped company — we need to understand how drugs
                    are made and how models are trained. Our team reflects that. If this
                    sounds like you, come <a class="underline" href="mailto:jobs@tacitlabs.co">join</a>.
                </p>
            </div>

            <!-- Role description (revealed on hover) -->
            <div class="col-span-7 col-start-10 grid">
                <h3
                    data-role-header
                    class="uppercase font-mono font-light text-xs tracking-normal leading-normal opacity-0 invisible transition-opacity duration-200 col-start-1 row-start-1"
                >
                    Role
                </h3>
                {
                    roles.map((r) => (
                        <p
                            data-synopsis
                            data-id={r.id}
                            class="col-start-1 row-start-2 font-display text-sm tracking-normal leading-normal opacity-0 invisible transition-opacity duration-200"
                        >
                            {r.description}
                        </p>
                    ))
                }
            </div>
        </div>
    </main>
</Layout>

<script>
    function initJoinUs() {
        const root = document.getElementById("role-titles");
        const titles = root?.querySelectorAll<HTMLElement>("[data-title]");
        const panels = document.querySelectorAll<HTMLElement>("[data-synopsis]");
        const headers = document.querySelectorAll<HTMLElement>("[data-role-header]");

        function show(id: string | null) {
            panels.forEach((p) => {
                const active = p.dataset.id === id;
                p.classList.toggle("opacity-0", !active);
                p.classList.toggle("invisible", !active);
            });
            headers.forEach((h) => h.classList.remove("opacity-0", "invisible"));
            titles?.forEach((t) =>
                t.classList.toggle("opacity-40", t.dataset.target !== id),
            );
        }

        function hideAll() {
            panels.forEach((p) => p.classList.add("opacity-0", "invisible"));
            headers.forEach((h) => h.classList.add("opacity-0", "invisible"));
            titles?.forEach((t) => t.classList.remove("opacity-40"));
        }

        titles?.forEach((t) => {
            t.addEventListener("mouseenter", () =>
                show(t.dataset.target ?? null),
            );
        });

        root?.addEventListener("mouseleave", hideAll);
    }

    document.addEventListener("astro:page-load", initJoinUs);
</script>
