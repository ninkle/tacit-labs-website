---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const jobs = (await getCollection("jobs")).sort(
    (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
const rendered = await Promise.all(jobs.map((j) => render(j)));
---

<Layout title="Tacit Labs — Careers">
    <main class="p-gutter flex flex-col min-h-dvh">
        <div class="mt-14 min-[810px]:mt-18 grow">
            <p
                class="font-mono font-light text-xs uppercase tracking-normal mb-4"
            >
                Opportunities
            </p>
            <div>
                {
                    jobs.map((job, i) => {
                        const { Content } = rendered[i];
                        return (
                            <details class="job-item border-t border-[#C4C4C4]">
                                <summary class="grid grid-cols-8 min-[810px]:grid-cols-16 gap-gutter w-full py-3 cursor-pointer items-baseline">
                                    <span class="col-span-6 min-[810px]:col-span-14 font-display text-md">
                                        {job.data.title}
                                    </span>
                                    <span class="col-span-2 min-[810px]:col-span-2 text-right font-mono font-light text-xs">
                                        {job.data.status}
                                    </span>
                                </summary>
                                <div class="job-prose pb-10 pt-2">
                                    <Content />
                                </div>
                            </details>
                        );
                    })
                }
                <div class="border-t border-[#C4C4C4]"></div>
            </div>
        </div>
    </main>
</Layout>

<style>
    /* Remove browser default disclosure triangle */
    .job-item > summary {
        list-style: none;
    }
    .job-item > summary::-webkit-details-marker {
        display: none;
    }

    /* Markdown: h2 → mono label, matches site's section header style */
    .job-prose :global(h2) {
        font-family: var(--font-mono);
        font-weight: 300;
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: normal;
        line-height: normal;
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
    }

    /* Body paragraphs */
    .job-prose :global(p) {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        line-height: 155%;
        max-width: 56ch;
        margin-bottom: 0.5rem;
    }

    /* Bullet lists */
    .job-prose :global(ul) {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        margin-bottom: 0.5rem;
    }
    .job-prose :global(li) {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        line-height: 155%;
        max-width: 56ch;
        padding-left: 1.25rem;
        position: relative;
    }
    .job-prose :global(li)::before {
        content: "—";
        position: absolute;
        left: 0;
        font-family: var(--font-display);
    }

    /* Strong within body */
    .job-prose :global(strong) {
        font-weight: 400;
    }
</style>

<script>
    // Close all other items when one opens, so only one is active at a time.
    function initJobList() {
        const items = document.querySelectorAll<HTMLDetailsElement>("details.job-item");
        items.forEach((item) => {
            item.addEventListener("toggle", () => {
                if (item.open) {
                    items.forEach((other) => {
                        if (other !== item) other.open = false;
                    });
                }
            });
        });
    }

    document.addEventListener("astro:page-load", initJobList);
</script>
