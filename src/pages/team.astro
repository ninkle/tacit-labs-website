        </div>
        <div
            id="team-footer"
            class="relative grid gap-gutter gap-y-6 min-[810px]:gap-y-gutter grid-cols-8 min-[810px]:grid-cols-16 w-full h-fit font-mono font-light text-xs tracking-normal leading-normal pt-gutter"
        >
            <div
                class="col-span-8 min-[810px]:col-span-6 xl:col-span-4 flex flex-col gap-gutter"
