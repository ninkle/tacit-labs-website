                        class="underline break-all">jobs@tacitlabs.co</a
                    >
                </p>
            </div>
        </div>
    </main>

    <script>
        import { gsap } from "gsap";

        // gsap.matchMedia instance for the current page. Kept at module scope so
        // we can revert it before the ClientRouter swaps the DOM (otherwise the
        // window-bound resize listener it registers would leak each navigation).
        let mm: gsap.MatchMedia | null = null;

        function initTeam() {
            const team = document.querySelector<HTMLElement>("[data-team]");
            if (!team) return;

            type CardRefs = {
                card: HTMLElement;
                name: HTMLElement;
                role: HTMLElement;
                links: HTMLElement;
                active: boolean;
            };

            const refs: CardRefs[] = Array.from(
                team.querySelectorAll<HTMLElement>("[data-card]"),
            ).map((card) => ({
                card,
                name: card.querySelector<HTMLElement>("[data-name]")!,
                role: card.querySelector<HTMLElement>("[data-role]")!,
                links: card.querySelector<HTMLElement>("[data-links]")!,
                active: false,
            }));

            // The RESTING (centered) name position is done purely with CSS
            // (`self-center` on the name, see markup) so it's always pixel-
            // perfect on load — no JS measurement that could race the font swap
            // or layout. We only measure the slide distance at hover time, when
            // the font is loaded and layout is settled, and translate the name
            // from its centered position to the left edge of the card.
            const leftShift = (r: CardRefs) =>
                -(r.card.clientWidth - r.name.offsetWidth) / 2;

            const setActive = (active: CardRefs | null) => {
                refs.forEach((r) => {
                    const isActive = active !== null && r === active;
                    r.active = isActive;

                    gsap.to(r.card, {
                        opacity: active === null || isActive ? 1 : 0.2,
                        duration: 0.5,
                        ease: "power3.out",
                        overwrite: "auto",
                    });

                    // Active: slide left from the CSS-centered resting position.
                    // Otherwise: return to x:0 (i.e. the centered resting spot).
                    gsap.to(r.name, {
                        x: isActive ? leftShift(r) : 0,
                        duration: 0.6,
                        ease: "power3.out",
                        overwrite: "auto",
                    });

                    gsap.to([r.role, r.links], {
                        autoAlpha: isActive ? 1 : 0,
                        duration: isActive ? 0.7 : 0.5,
                        ease: "power3.out",
                        overwrite: "auto",
                    });
                });
            };

            // Only enable the hover interaction at >=810px. Below that (mobile),
            // every card stays in its expanded state via CSS with no JS, and
            // gsap.matchMedia reverts any inline styles when we cross down.
            mm = gsap.matchMedia();
            mm.add("(min-width: 810px)", () => {
                // Hide role/links without removing them from flow — their space
                // stays reserved so images never shift on expand. Names keep
                // their CSS-centered position; no transform is set at rest.
                refs.forEach((r) =>
                    gsap.set([r.role, r.links], { autoAlpha: 0 }),
                );

                const onEnter = refs.map((r) => {
                    const handler = () => setActive(r);
                    r.card.addEventListener("mouseenter", handler);
                    return handler;
                });
                const onLeave = () => setActive(null);
                team.addEventListener("mouseleave", onLeave);

                return () => {
                    refs.forEach((r, i) =>
                        r.card.removeEventListener("mouseenter", onEnter[i]),
                    );
                    team.removeEventListener("mouseleave", onLeave);
                    // Reset to the static expanded state mobile expects.
                    refs.forEach((r) => {
                        r.active = false;
                        gsap.set(r.card, { clearProps: "opacity" });
                        gsap.set(r.name, { clearProps: "transform" });
                        gsap.set([r.role, r.links], {
                            clearProps: "opacity,visibility",
                        });
                    });
                };
            });
        }

        // Run on first load AND after every ClientRouter navigation. Astro only
        // evaluates a page's module script once, so without this the hover setup
        // would never run when arriving at /team via a client-side navigation.
        document.addEventListener("astro:page-load", initTeam);

        // Tear down before the DOM is swapped away so the matchMedia's
        // window/resize listeners don't accumulate across navigations.
        document.addEventListener("astro:before-swap", () => {
            mm?.revert();
            mm = null;
        });
    </script>
</Layout>
