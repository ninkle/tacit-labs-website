---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import headshot from "../images/headshot.jpg";

import annemarie from "../images/annemarie.jpg";
import katie from "../images/katie.jpg";
import max from "../images/max.jpg";
import nicole from "../images/nicole.jpg";
---

<Layout title="Tacit Labs">
    <main class="p-gutter flex flex-col min-h-dvh min-[810px]:h-screen">
        <div class="flex flex-col justify-center w-full grow pt-6.5 pb-6.5">
            <div class="grid grid-cols-8 min-[810px]:grid-cols-16 gap-gutter">
                <div
                    data-team
                    class="col-span-8 grid grid-cols-2 gap-gutter min-[810px]:col-span-12 min-[810px]:col-start-3 min-[810px]:flex min-[810px]:flex-row min-[810px]:gap-1 min-[1200px]:col-span-8 min-[1200px]:col-start-5"
                >
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={nicole}
                                alt="Nicole Fitzgerald"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
                                    Nicole Fitzgerald
                                </h3>
                                <h3
                                    data-role
                                    class="font-display italic text-sm opacity-100 min-[810px]:opacity-0"
                                >
                                    Co-Founder/CEO
                                </h3>
                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[8px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a href="/" class="nav-underline">LinkedIn</a>
                                <a href="/" class="nav-underline">X.COM</a>
                            </div>
                        </div>
                    </div>
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={annemarie}
                                alt="Anne Marie Droste"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
                                    Anne Marie Droste
                                </h3>
                                <h3
                                    data-role
                                    class="font-display italic text-sm opacity-100 min-[810px]:opacity-0"
                                >
                                    Co-Founder/CEO
                                </h3>
                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[8px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a href="/" class="nav-underline">LinkedIn</a>
                                <a href="/" class="nav-underline">X.COM</a>
                            </div>
                        </div>
                    </div>
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={max}
                                alt="Max Marion"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
                                    Max Marion
                                </h3>
                                <h3
                                    data-role
                                    class="font-display italic text-sm opacity-100 min-[810px]:opacity-0"
                                >
                                    Founding Member of Technical Staff
                                </h3>
                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[8px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a href="/" class="nav-underline">LinkedIn</a>
                                <a href="/" class="nav-underline">X.COM</a>
                            </div>
                        </div>
                    </div>
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={katie}
                                alt="Katie-Rose Skelly"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
                                    Katie-Rose Skelly
                                </h3>
                                <h3
                                    data-role
                                    class="font-display italic text-sm opacity-100 min-[810px]:opacity-0"
                                >
                                    Chief Platform Officer
                                </h3>
                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[8px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a href="/" class="nav-underline">LinkedIn</a>
                                <a href="/" class="nav-underline">X.COM</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div
            id="team-footer"
            class="relative grid gap-gutter grid-cols-8 min-[810px]:grid-cols-16 w-full h-fit font-mono font-light text-xs tracking-normal leading-normal pt-gutter"
        >
            <div
                class="col-span-3 min-[810px]:col-span-6 xl:col-span-4 text-xs"
            >
                CONTACT
            </div>
            <div
                class="col-span-3 min-[810px]:col-span-4 xl:col-span-4 text-xs"
            >
                SOCIALS
            </div>
            <div class="col-span-2 min-[810px]:col-span-6 text-xs">JOBS</div>
            <p class="col-span-3 min-[810px]:col-span-6 xl:col-span-4">
                <span
                    ><a href="mailto:info@tacitlabs.co" class="underline"
                        >info@tacitlabs.co</a
                    ></span
                ><br /><br />

                360 3rd St 5th floor<br />
                San Francisco, CA 94107
            </p>
            <ul class="col-span-3 min-[810px]:col-span-4 xl:col-span-4">
                <li>
                    <a
                        href="https://www.linkedin.com/in/tacitlabs/"
                        target="_blank">LinkedIn</a
                    >
                </li>
                <li>
                    <a href="https://github.com/tacitlabs" target="_blank"
                        >X.COM</a
                    >
                </li>
            </ul>
            <p class="col-span-2 min-[810px]:col-span-6">
                <a href="mailto:jobs@tacitlabs.co" class="underline"
                    >jobs@tacitlabs.co</a
                >
            </p>
        </div>
    </main>

    <script>
        import { gsap } from "gsap";

        const team = document.querySelector<HTMLElement>("[data-team]");

        if (team) {
            type CardRefs = {
                card: HTMLElement;
                name: HTMLElement;
                role: HTMLElement;
                links: HTMLElement;
                offset: number;
                active: boolean;
            };

            const refs: CardRefs[] = Array.from(
                team.querySelectorAll<HTMLElement>("[data-card]"),
            ).map((card) => ({
                card,
                name: card.querySelector<HTMLElement>("[data-name]")!,
                role: card.querySelector<HTMLElement>("[data-role]")!,
                links: card.querySelector<HTMLElement>("[data-links]")!,
                offset: 0,
                active: false,
            }));

            // Measure how far each (collapsed) name must shift to read as
            // centered under its image, then drive that purely with transforms
            // so the slide is smooth. Skip active cards — they sit at x:0.
            const measure = () => {
                refs.forEach((r) => {
                    if (r.active) return;
                    r.offset = (r.card.clientWidth - r.name.offsetWidth) / 2;
                    gsap.set(r.name, { x: r.offset });
                });
            };

            const setActive = (active: CardRefs | null) => {
                refs.forEach((r) => {
                    const isActive = active !== null && r === active;
                    r.active = isActive;

                    gsap.to(r.card, {
                        opacity: active === null || isActive ? 1 : 0.2,
                        duration: 0.5,
                        ease: "power3.out",
                        overwrite: "auto",
                    });

                    gsap.to(r.name, {
                        x: isActive ? 0 : r.offset,
                        duration: 0.6,
                        ease: "power3.out",
                        overwrite: "auto",
                    });

                    gsap.to([r.role, r.links], {
                        autoAlpha: isActive ? 1 : 0,

                        duration: isActive ? 0.7 : 0.5,
                        ease: isActive ? "power3.out" : "power3.out",
                        overwrite: "auto",
                    });
                });
            };

            // Only enable the hover interaction at >=810px. Below that (mobile),
            // every card stays in its expanded state via CSS with no JS, and
            // gsap.matchMedia reverts any inline styles when we cross down.
            const mm = gsap.matchMedia();
            mm.add("(min-width: 810px)", () => {
                // Swap CSS centering for transform centering without a visual
                // jump, and hide role/links without removing them from flow —
                // their space stays reserved so images never shift on expand.
                refs.forEach((r) => {
                    r.name.classList.remove("self-center");
                    r.name.classList.add("self-start");
                    gsap.set([r.role, r.links], { autoAlpha: 0 });
                });
                measure();
                // Re-measure once the custom display font has loaded (its
                // metrics change the name width).
                document.fonts?.ready.then(measure);

                const onEnter = refs.map((r) => {
                    const handler = () => setActive(r);
                    r.card.addEventListener("mouseenter", handler);
                    return handler;
                });
                const onLeave = () => setActive(null);
                team.addEventListener("mouseleave", onLeave);

                let resizeRAF = 0;
                const onResize = () => {
                    cancelAnimationFrame(resizeRAF);
                    resizeRAF = requestAnimationFrame(measure);
                };
                window.addEventListener("resize", onResize);

                return () => {
                    refs.forEach((r, i) =>
                        r.card.removeEventListener("mouseenter", onEnter[i]),
                    );
                    team.removeEventListener("mouseleave", onLeave);
                    window.removeEventListener("resize", onResize);
                    cancelAnimationFrame(resizeRAF);
                    // Reset to the static expanded state mobile expects.
                    refs.forEach((r) => {
                        r.active = false;
                        gsap.set(r.card, { clearProps: "opacity" });
                        gsap.set(r.name, { clearProps: "transform" });
                        gsap.set([r.role, r.links], {
                            clearProps: "opacity,visibility",
                        });
                    });
                };
            });
        }
    </script>
</Layout>
