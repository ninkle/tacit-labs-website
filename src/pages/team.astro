                                src={nicole}
                                alt="Nicole Fitzgerald"
                                loading="eager"
                                fetchpriority="high"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
