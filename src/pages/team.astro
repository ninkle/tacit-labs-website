                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[10px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a
                                    href="https://www.linkedin.com/in/nicole-fitzgerald/?skipRedirect=true"
                                    class="nav-underline">LinkedIn</a
                                >
                                <a
                                    href="https://x.com/ninklefitz"
                                    class="nav-underline">X.COM</a
                                >
                            </div>
                        </div>
                    </div>
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={annemarie}
                                alt="Anne Marie Droste"
                                loading="eager"
                                fetchpriority="high"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
                                    Anne Marie Droste
                                </h3>
                                <h3
                                    data-role
                                    class="font-display italic text-sm opacity-100 min-[810px]:opacity-0"
                                >
                                    Co-Founder/COO
                                </h3>
                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[10px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a
                                    href="https://www.linkedin.com/in/amdroste/"
                                    class="nav-underline">LinkedIn</a
                                >
                                <a
                                    href="https://x.com/AmDroste"
                                    class="nav-underline">X.COM</a
                                >
                            </div>
                        </div>
                    </div>
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={max}
                                alt="Max Marion"
                                loading="eager"
                                fetchpriority="high"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
                                    Max Marion
                                </h3>
                                <h3
                                    data-role
                                    class="font-display italic text-sm opacity-100 min-[810px]:opacity-0"
                                >
                                    Founding Member of Technical Staff
                                </h3>
                            </div>
                            <div
                                data-links
                                class="flex flex-row font-mono font-light gap-gutter text-[10px] uppercase opacity-100 min-[810px]:opacity-0"
                            >
                                <a
                                    href="https://www.linkedin.com/in/max-marion/"
                                    class="nav-underline">LinkedIn</a
                                >
                                <a
                                    href="https://x.com/maxisawesome538"
                                    class="nav-underline">X.COM</a
                                >
                            </div>
                        </div>
                    </div>
                    <div
                        data-card
                        class="flex flex-col justify-start grow gap-1.5"
                    >
                        <div class="aspect-5/7">
                            <Picture
                                src={katie}
                                alt="Katie-Rose Skelly"
                                loading="eager"
                                fetchpriority="high"
                                class="w-full h-full object-cover"
                            />
                        </div>
                        <div class="flex flex-col items-start gap-3 text-left">
                            <div class="flex flex-col gap-0 w-full">
                                <h3
                                    data-name
                                    class="font-display text-sm self-center max-[809px]:self-start w-fit"
                                >
