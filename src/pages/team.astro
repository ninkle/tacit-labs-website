            </div>
            <div
                class="col-span-4 min-[810px]:col-span-4 flex flex-col gap-gutter"
            >
                <div class="text-xs">SOCIALS</div>
                <ul>
                    <li>
                        <a
                            href="https://www.linkedin.com/company/tacit-labs/about/"
                            target="_blank"
                            class="nav-underline">LinkedIn</a
                        >
                    </li>
                    <li>
                        <a
                            href="https://x.com/tacitlabsco"
                            target="_blank"
                            class="nav-underline">X.COM</a
                        >
                    </li>
                </ul>
            </div>
            <div
                class="col-span-4 min-[810px]:col-span-6 flex flex-col gap-gutter"
            >
                <div class="text-xs">JOBS</div>
                <p>
                    <a
