---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import blog001 from "../images/blog001.jpg";
---

<Layout title="Tacit Labs">
    <main class="p-gutter flex flex-col min-h-dvh min-[810px]:h-screen">
        <div
            class="flex flex-col justify-center w-full h-fit grow pt-6.5 pb-6.5"
        >
            <div class="grid grid-cols-16 gap-gutter h-fit">
                <div class="col-start-1 col-span-3 font-display text-sm">
                    Blog
                </div>
                <a
                    href="/introducing-tacit-labs"
                    class="col-span-4 col-start-4 flex flex-col gap-2"
                >
                    <div
                        class="aspect-7/5 w-full h-auto overflow-clip col-span-4"
                    >
                        <Picture
                            src={blog001}
                            alt="Headshot"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div class="flex flex-col gap-0">
                        <h2 class="font-display text-sm">
                            Introducing Tacit Labs
                        </h2>
                        <h2 class="font-display text-sm italic">
                            June 09, 2026
                        </h2>
                    </div>
                </a>
            </div>
        </div>
        <div
            id="team-footer"
            class="relative place-items-baseline grid gap-gutter grid-cols-8 min-[810px]:grid-cols-16 w-full h-fit font-mono font-light text-xs tracking-normal leading-normal pt-gutter"
        >
            <div
                class="col-span-3 min-[810px]:col-span-6 xl:col-span-4 text-xs"
            >
                CONTACT
            </div>
            <div
                class="col-span-3 min-[810px]:col-span-4 xl:col-span-4 text-xs"
            >
                SOCIALS
            </div>
            <div class="col-span-2 min-[810px]:col-span-6 text-xs">JOBS</div>
            <p class="col-span-3 min-[810px]:col-span-6 xl:col-span-4">
                <span
                    ><a href="mailto:info@tacitlabs.co" class="underline"
                        >info@tacitlabs.co</a
                    ></span
                ><br /><br />

                360 3rd St 5th floor<br />
                San Francisco, CA 94107
            </p>
            <ul class="col-span-3 min-[810px]:col-span-4 xl:col-span-4">
                <li>
                    <a
                        href="https://www.linkedin.com/in/tacitlabs/"
                        target="_blank">LinkedIn</a
                    >
                </li>
                <li>
                    <a href="https://github.com/tacitlabs" target="_blank"
                        >X.COM</a
                    >
                </li>
            </ul>
            <p class="col-span-2 min-[810px]:col-span-6">
                <a href="mailto:jobs@tacitlabs.co" class="underline"
                    >jobs@tacitlabs.co</a
                >
            </p>
        </div>
    </main>
</Layout>
