---
import { ClientRouter } from "astro:transitions";
import "@fontsource/roboto-mono/300.css";
import "@fontsource/roboto-mono/400.css";
import "@fontsource/roboto-mono/500.css";
import "../styles/global.css";

interface Props {
    title?: string;
}

const { title = "Tacit Labs" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
    </head>
    <body class="min-h-dvh bg-[#EDEFEB] text-black antialiased">
        <nav
            class="fixed top-gutter right-gutter left-gutter flex flex-row gap-gutter justify-between min-[810px]:justify-start items-center z-50"
        >
            <a href="/" transition:persist>
                <img
                    src="/favicon.svg"
                    alt="Tacit Labs"
                    data-logo
                    class="logo size-7 block"
                />
            </a>

            <div
                class="hidden min-[810px]:flex flex-row gap-25 pl-15 font-light text-xs font-mono tracking-normal leading-normal"
            >
                <a href="/team" class="nav-underline">TEAM</a>
                <a href="/introducing-tacit-labs" class="nav-underline">BLOG</a>
            </div>

            <button
                type="button"
                id="menu-toggle"
                aria-expanded="false"
                aria-controls="mobile-menu"
                class="text-right font-mono font-light text-xs tracking-normal leading-normal cursor-pointer z-50 min-[810px]:hidden"
            >
                MENU
            </button>
        </nav>

        <!-- Mobile menu: slides down 200px from the top below 810px. -->
        <div
            id="mobile-menu"
            data-open="false"
            class="menu-panel fixed top-0 left-0 right-0 h-[200px] border-b border-[#C4C4C4] bg-[#EDEFEB] z-40 flex flex-row items-center justify-center min-[810px]:hidden"
        >
            <div
                class="flex flex-col items-center gap-0 font-mono font-light text-xs tracking-normal leading-normal"
            >
                <a href="/team">TEAM</a>
                <a href="/introducing-tacit-labs">BLOG</a>
            </div>
        </div>

        <slot />

        <style is:global>
            @keyframes logo-spin {
                from {
                    transform: rotate(0deg);
                }
                to {
                    transform: rotate(360deg);
                }
            }
            .logo--spin {
                animation: logo-spin 0.6s ease-in-out;
            }
        </style>

        <script>
            // Use delegation + element lookups so the menu keeps working after
            // client-side navigations (ClientRouter swaps the nav DOM, which
            // would orphan listeners bound directly to the elements).
            function setOpen(open: boolean) {
                const menu = document.getElementById("mobile-menu");
                const toggle = document.getElementById("menu-toggle");
                if (menu) menu.dataset.open = String(open);
                toggle?.setAttribute("aria-expanded", String(open));
            }

            document.addEventListener("click", (e) => {
                const target = e.target as Element | null;
                if (target?.closest("#menu-toggle")) {
                    const menu = document.getElementById("mobile-menu");
                    setOpen(menu?.dataset.open !== "true");
                }

                const logo = target?.closest<HTMLElement>("[data-logo]");
                if (logo) {
                    logo.classList.remove("logo--spin");
                    void logo.offsetWidth;
                    logo.classList.add("logo--spin");
                }
            });

            document.addEventListener("animationend", (e) => {
                const t = e.target as Element | null;
                if (t?.matches("[data-logo]")) t.classList.remove("logo--spin");
            });

            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape") setOpen(false);
            });
            window.addEventListener("resize", () => {
                if (window.innerWidth >= 810) setOpen(false);
            });
        </script>
    </body>
</html>
