---
import { ClientRouter } from "astro:transitions";
import "@fontsource/roboto-mono/300.css";
import "@fontsource/roboto-mono/400.css";
import "@fontsource/roboto-mono/500.css";
import "../styles/global.css";

interface Props {
    title?: string;
}

const { title = "Tacit Labs" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
    </head>
    <body class="min-h-dvh bg-offwhite text-black antialiased">
        <nav
            class="fixed top-gutter left-gutter right-gutter flex flex-row gap-gutter items-center z-50"
        >
            <a href="/">
                <img src="/favicon.svg" alt="Tacit Labs" class="size-5 block" />
            </a>

            <div
                class="hidden min-[810px]:flex flex-row gap-20 pl-10 font-light text-xs font-mono tracking-normal leading-normal"
            >
                <a href="/team" class="nav-underline">TEAM</a>
                <a href="/blog" class="nav-underline">BLOG</a>
                <a href="/join-us" class="nav-underline">JOIN US</a>
            </div>

            <button
                type="button"
                id="menu-toggle"
                aria-expanded="false"
                aria-controls="mobile-menu"
                class="ml-auto flex justify-end font-mono font-light text-xs tracking-normal leading-normal cursor-pointer z-50 min-[810px]:hidden"
            >
                MENU
            </button>
        </nav>

        <!-- Mobile menu: slides down 200px from the top below 810px. -->
        <div
            id="mobile-menu"
            data-open="false"
            class="menu-panel fixed top-0 left-gutter right-gutter h-[200px] border-b border-[#C4C4C4] bg-offwhite z-40 flex flex-row items-center justify-center min-[810px]:hidden"
        >
            <div
                class="flex flex-col items-center gap-0 font-mono font-light text-xs tracking-normal leading-normal"
            >
                <a href="/team">TEAM</a>
                <a href="/">BLOG</a>
                <a href="/">JOIN US</a>
            </div>
        </div>

        <slot />

        <script>
            // Use delegation + element lookups so the menu keeps working after
            // client-side navigations (ClientRouter swaps the nav DOM, which
            // would orphan listeners bound directly to the elements).
            function setOpen(open: boolean) {
                const menu = document.getElementById("mobile-menu");
                const toggle = document.getElementById("menu-toggle");
                if (menu) menu.dataset.open = String(open);
                toggle?.setAttribute("aria-expanded", String(open));
            }

            document.addEventListener("click", (e) => {
                const target = e.target as Element | null;
                if (target?.closest("#menu-toggle")) {
                    const menu = document.getElementById("mobile-menu");
                    setOpen(menu?.dataset.open !== "true");
                }
            });

            // Close on Escape, and when the viewport grows past the breakpoint
            // (so it can't stay open behind the desktop nav).
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape") setOpen(false);
            });
            window.addEventListener("resize", () => {
                if (window.innerWidth >= 810) setOpen(false);
            });
        </script>
    </body>
</html>
