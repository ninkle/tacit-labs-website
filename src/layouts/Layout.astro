---
import "@fontsource/roboto-mono/300.css";
import "@fontsource/roboto-mono/400.css";
import "@fontsource/roboto-mono/500.css";
import "../styles/global.css";

interface Props {
    title?: string;
}

const { title = "Tacit Labs" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="min-h-dvh bg-offwhite text-black antialiased">
        <nav
            class="fixed top-gutter left-gutter right-gutter grid grid-cols-16 gap-gutter z-50"
        >
            <a
                href="/"
                class="font-display text-[1.5rem] tracking-normal leading-normal col-span-4"
                >Tacit Labs</a
            >
            <div
                class="flex flex-row justify-end gap-20 col-span-4 col-start-13"
            >
                <a
                    href="/team"
                    class="font-mono font-light text-[0.875rem] tracking-normal leading-normal"
                >
                    TEAM
                </a>
                <a
                    href="/research"
                    class="font-mono font-light text-[0.875rem] tracking-normal leading-normal"
                >
                    RESEARCH
                </a>
                <a
                    href="/"
                    class="font-mono font-light text-[0.875rem] tracking-normal leading-normal"
                >
                    BLOG
                </a>
                <a
                    href="/"
                    class="font-mono font-light text-[0.875rem] tracking-normal leading-normal"
                >
                    CONTACT
                </a>
            </div>
        </nav>
        <slot />
    </body>
</html>
